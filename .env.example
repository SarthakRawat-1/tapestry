# ==============================================================================
# HISTORY RESEARCH AI - Environment Variables Template
# ==============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# ==============================================================================

# ------------------------------------------------------------------------------
# APP CONFIGURATION
# ------------------------------------------------------------------------------
# Your app URL (use http://localhost:3000 for local development)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# MONGODB (REQUIRED)
# ------------------------------------------------------------------------------
# MongoDB Atlas connection string
# Get yours at: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=history

# ------------------------------------------------------------------------------
# JWT SECRET (REQUIRED)
# ------------------------------------------------------------------------------
# Used for signing session tokens — use a long random string in production
JWT_SECRET=change-me-in-production

# ------------------------------------------------------------------------------
# GOOGLE MAPS API (REQUIRED)
# ------------------------------------------------------------------------------
# Used for interactive 3D globe visualization
# Get your API key at: https://console.cloud.google.com/google/maps-apis
# Enable "Map Tiles API" and "Maps JavaScript API" in your GCP console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ------------------------------------------------------------------------------
# GEMINI API (REQUIRED)
# ------------------------------------------------------------------------------
# Powers the AI storytelling research engine
# Get your API key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# TAVILY API (REQUIRED)
# ------------------------------------------------------------------------------
# Used for historical image search
# Get your API key at: https://tavily.com
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# ------------------------------------------------------------------------------
# GOOGLE CLOUD PLATFORM (OPTIONAL)
# ------------------------------------------------------------------------------
# API key for TTS and Translate (simple REST APIs)
# Enable these APIs in your GCP console:
#   - Cloud Text-to-Speech API
#   - Cloud Translation API
#   - Imagen API (uses GEMINI_API_KEY above)
# Get your API key at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here

# Google Cloud Storage (for persisting generated audio and images)
# Create a bucket at: https://console.cloud.google.com/storage
# Create a service account with Storage Object Admin role
# Option 1 (local dev): point to the JSON key file
# Option 2 (production/Docker): paste the JSON string
GCS_BUCKET_NAME=your_bucket_name_here
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCS_CREDENTIALS={"type":"service_account","project_id":"...",...}

# ------------------------------------------------------------------------------
# ENTERPRISE FEATURES (OPTIONAL)
# ------------------------------------------------------------------------------
# Set to 'true' to enable enterprise contact options
NEXT_PUBLIC_ENTERPRISE=false
