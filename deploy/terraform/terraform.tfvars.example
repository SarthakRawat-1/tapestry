project_id = "your-gcp-project-id"
region     = "us-central1"

service_name        = "tapestry"
artifact_repository = "tapestry"
container_image     = "us-central1-docker.pkg.dev/your-gcp-project-id/tapestry/tapestry:latest"

cpu                     = "1"
memory                  = "2Gi"
min_instances           = 0
max_instances           = 10
request_timeout_seconds = 300
allow_unauthenticated   = true
ingress                 = "INGRESS_TRAFFIC_ALL"

plain_env_vars = {
  NODE_ENV                        = "production"
  NEXT_PUBLIC_APP_URL             = "https://your-service-url.run.app"
  MONGODB_DB_NAME                 = "history"
  NEXT_PUBLIC_GOOGLE_MAPS_API_KEY = "your_google_maps_api_key"
  GOOGLE_SITE_VERIFICATION        = ""
  GCS_BUCKET_NAME                 = ""
}

secret_env_vars = {
  MONGODB_URI          = "mongodb+srv://..."
  JWT_SECRET           = "replace_with_secure_random_value"
  GEMINI_API_KEY       = "your_gemini_api_key"
  TAVILY_API_KEY       = "your_tavily_api_key"
  GOOGLE_CLOUD_API_KEY = "your_google_cloud_api_key"
  GCS_CREDENTIALS      = "{\"type\":\"service_account\",...}"
}
